{
  "name": "web-scholar-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test:cucumber": "cucumber-js -r ts-node/register --require features/steps/**/*.ts --publish-quiet",
    "test": "npm run test:cucumber"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "luxon": "^3.5.0",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^10.4.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "@types/supertest": "^2.0.16",
    "@types/uuid": "^9.0.8",
    "supertest": "^6.3.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
